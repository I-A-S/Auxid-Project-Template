{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28
  },
  "configurePresets": [
    {
      "name": "${AUXID_PROJECT_NAME}-x64-linux",
      "displayName": "${AUXID_PROJECT_NAME} Linux x64 (Clang)",
      "inherits": "x64-linux",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/libauxid/cmake/toolchains/x64-linux-clang.cmake"
      }
    },
    {
      "name": "${AUXID_PROJECT_NAME}-arm64-linux",
      "displayName": "${AUXID_PROJECT_NAME} Linux ARM64 (Clang Cross)",
      "inherits": "arm64-linux",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/libauxid/cmake/toolchains/arm64-linux-clang.cmake"
      }
    },
    {
      "name": "${AUXID_PROJECT_NAME}-x64-windows",
      "displayName": "${AUXID_PROJECT_NAME} Windows x64 (Clang)",
      "inherits": "x64-windows",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/libauxid/cmake/toolchains/x64-windows-clang.cmake"
      }
    },
    {
      "name": "${AUXID_PROJECT_NAME}-arm64-windows",
      "displayName": "${AUXID_PROJECT_NAME} Windows ARM64 (Clang Cross)",
      "inherits": "arm64-windows",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/libauxid/cmake/toolchains/arm64-windows-clang.cmake"
      }
    },
    {
      "name": "${AUXID_PROJECT_NAME}-x64-windows-cross",
      "displayName": "${AUXID_PROJECT_NAME} Windows x64 (Clang Cross Linux Host)",
      "inherits": "x64-windows-cross",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/libauxid/cmake/toolchains/x64-windows-cross-clang.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "${AUXID_PROJECT_NAME}-x64-linux",
      "configurePreset": "${AUXID_PROJECT_NAME}-x64-linux"
    },
    {
      "name": "${AUXID_PROJECT_NAME}-x64-windows",
      "configurePreset": "${AUXID_PROJECT_NAME}-x64-windows"
    }
  ],
  "testPresets": [
    {
      "name": "${AUXID_PROJECT_NAME}-x64-linux",
      "configurePreset": "${AUXID_PROJECT_NAME}-x64-linux",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "${AUXID_PROJECT_NAME}-x64-windows",
      "configurePreset": "${AUXID_PROJECT_NAME}-x64-windows",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "include": [
    "libauxid/CMakePresets.json"
  ]
}